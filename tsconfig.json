{
  "compilerOptions": {
    // 언어 및 환경
    "target": "ES2022",
    "types": ["node", "express", "multer"],
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,

    // 모듈 해석
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    // 타입 검사
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // 출력 설정
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // 소스맵
    "sourceMap": true,

    // 기타
    "allowJs": false,
    "removeComments": true,
    "incremental": true
  },
  "include": ["src/**/*", "auth"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
